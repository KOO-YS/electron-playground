{
  "name": "electron-auto-update-sample",
  "version": "1.0.0",
  "description": "Electron auto-update sample with GitHub Releases",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "release:win": "electron-builder --win --x64 && echo 'Build complete. Run: ./scripts/release.sh <version>'"
  },
  "build": {
    "appId": "com.sample.electron-auto-update",
    "productName": "ElectronAutoUpdateSample",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        },
        {
          "target": "zip",
          "arch": ["universal"]
        }
      ],
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": true
    },
    "publish": {
      "provider": "github",
      "owner": "koo-ys",
      "repo": "https://github.com/KOO-YS/electron-playground",
      "releaseType": "release"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*"
    ],
    "extraResources": []
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  }
}
